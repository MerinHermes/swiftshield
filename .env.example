# ── MongoDB ─────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/
MONGO_DB=swiftshield

# ── Admin API Key ────────────────────────────────────────
ADMIN_API_KEY=change-this-to-a-strong-secret

# ── Office Geofence ──────────────────────────────────────
OFFICE_LAT=19.0219594
OFFICE_LON=73.0934445
OFFICE_RADIUS=2000

# ── CORS ─────────────────────────────────────────────────
ALLOWED_ORIGINS=https://swiftshield.in

# ── Email Alerts (Google Workspace / Gmail) ───────────────
# 1. Go to myaccount.google.com → Security → App Passwords
# 2. Create an App Password for "Mail"
# 3. Paste it below (NOT your real password)
ALERT_EMAIL_USER=alerts@swiftshield.in
ALERT_EMAIL_PASS=xxxx-xxxx-xxxx-xxxx
ALERT_EMAIL_TO=admin@swiftshield.in

# ── Server ───────────────────────────────────────────────
PORT=3000
