{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "crons": [
    {
      "path": "/api/drive/poll",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/drive/watch",
      "schedule": "0 9 * * *"
    }
  ]
}
